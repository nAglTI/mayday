<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_navigation"
    app:startDestination="@id/onboardingFragment">

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="org.debs.mayday.feature.onboarding.OnboardingFragment"
        android:label="@string/app_name">
        <action
            android:id="@+id/action_onboarding_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_onboarding_to_settings"
            app:destination="@id/settingsFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="org.debs.mayday.feature.home.HomeFragment"
        android:label="@string/app_name">
        <deepLink app:uri="mayday://home" />
        <action
            android:id="@+id/action_home_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="org.debs.mayday.feature.settings.SettingsFragment"
        android:label="@string/settings_title">
        <deepLink app:uri="mayday://settings" />
        <action
            android:id="@+id/action_settings_to_split"
            app:destination="@id/splitFragment" />
    </fragment>

    <fragment
        android:id="@+id/splitFragment"
        android:name="org.debs.mayday.feature.split.SplitFragment"
        android:label="@string/split_title">
        <deepLink app:uri="mayday://split" />
    </fragment>
</navigation>
